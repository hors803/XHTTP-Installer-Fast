{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "__PUBLIC_PATH__",
      "destination": "/api/index"
    },
    {
      "source": "__PUBLIC_PATH__/:path*",
      "destination": "/api/index"
    }
  ],
  "trailingSlash": false
}
